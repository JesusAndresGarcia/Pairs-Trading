# 1. Optimización
z_in, z_out = optimize_thresholds(df_kalman['z_score'], df_kalman['spread'].diff().fillna(0))

# 2. Aplicación de señales
df_kalman['signal'] = generate_signals_vecm(df_kalman, z_in, z_out)

